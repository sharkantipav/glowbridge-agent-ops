# Optional: anon key (only for client-side calls; backend uses service role)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFsemVndmNmbXh3b3ZoYWVsbWp6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjM2NTY1MzMsImV4cCI6MjA3OTIzMjUzM30.d205wyVltHmXDKN1DgJzoHA0Jv32hejNg0raVvA_M_E

# --- Gmail (OAuth via Google Cloud project) ---
# After running scripts/gmail_oauth.py, gmail_token.json is created (gitignored).
GMAIL_CLIENT_ID=...apps.googleusercontent.com
GMAIL_CLIENT_SECRET=...
GMAIL_FROM_ADDRESS=cb@glowbridge.ai
GMAIL_FROM_NAME=Charles at GlowBridge
# For deploy hosts without a persistent volume (Railway, Fly): paste the contents
# of your local gmail_token.json here (raw JSON or base64). The backend writes it
# to the expected file on startup. Leave blank when running locally.
GMAIL_TOKEN_JSON=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs
STRIPE_PRICE_SETUP=price_...   # $199 one-time setup fee
STRIPE_PRICE_MONTHLY=price_... # $99/month subscription

# --- Browserbase / Stagehand ---
BROWSERBASE_API_KEY=bb_...
BROWSERBASE_PROJECT_ID=...

# --- Web search (pick one) ---
# Brave Search API (recommended; 2k free/month):
BRAVE_API_KEY=
# Or Tavily:
TAVILY_API_KEY=

# --- Admin auth ---
# Simple bearer token for /admin endpoints. Rotate freely.
ADMIN_TOKEN=change-me-to-something-long-and-random

# --- Operator (where escalations go) ---
OPERATOR_EMAIL=charles@glowbridge.ai

# --- App ---
APP_ENV=development
APP_BASE_URL=http://localhost:8000
TIMEZONE=America/New_York

# --- Scheduler safety toggles ---
# When false, scheduled jobs run but don't actually send emails / call APIs.
# Useful for dry-run testing in production. Set to "true" to go live.
ENABLE_OUTREACH_SEND=false
ENABLE_REPLY_AUTOREPLY=false
ENABLE_SOCIAL_AUTOPOST=false
